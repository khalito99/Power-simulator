<!DOCTYPE html>
<html>
<head>
<title>Power Simulator RPG</title>

<style>
body {
  margin:0;
  background:black;
  color:white;
  font-family:Arial;
  text-align:center;
}

#game {
  margin-top:50px;
}

button {
  padding:15px;
  margin:10px;
  font-size:18px;
  border:none;
  border-radius:10px;
  background:purple;
  color:white;
}

.enemy {
  margin-top:20px;
}
</style>

</head>

<body>

<h1>⚡ POWER SIMULATOR RPG ⚡</h1>

<div id="game">
  <p>Level: <span id="level">1</span></p>
  <p>XP: <span id="xp">0</span></p>
  <p>Enemy HP: <span id="enemyHP">100</span></p>

  <button onclick="attack()">⚔️ Attack</button>
</div>

<script>

let level = 1
let xp = 0
let enemyHP = 100

function attack(){
  let damage = Math.floor(Math.random()*20)+10
  enemyHP -= damage

  if(enemyHP <= 0){
    xp += 50
    enemyHP = 100
    alert("Enemy defeated!")

    if(xp >= 100){
      level++
      xp = 0
      alert("LEVEL UP!")
    }
  }

  update()
}

function update(){
  document.getElementById("level").innerText = level
  document.getElementById("xp").innerText = xp
  document.getElementById("enemyHP").innerText = enemyHP
}

</script>

</body>
</html>
